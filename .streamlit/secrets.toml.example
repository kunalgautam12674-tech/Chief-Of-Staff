# Copy this file to secrets.toml and fill in your actual values
# For Streamlit Cloud deployment, set these in the Streamlit dashboard (Manage app > Secrets)

# Gemini API Key (required for AI triage and drafting)
GEMINI_API_KEY = "your_gemini_api_key_here"

# OAuth Configuration (for Gmail API access)
# For Streamlit Cloud, you'll need to use service account credentials or
# pre-authorized tokens. See deployment guide for details.

# Option 1: Service Account (recommended for production)
# GOOGLE_CREDENTIALS_JSON = '{"type": "service_account", ...}'

# Option 2: Pre-authorized OAuth token (for development)
# OAUTH_ACCESS_TOKEN = "your_access_token"
# OAUTH_REFRESH_TOKEN = "your_refresh_token"
# OAUTH_CLIENT_ID = "your_client_id"
# OAUTH_CLIENT_SECRET = "your_client_secret"
